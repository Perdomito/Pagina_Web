# Copia este archivo como .env y completa los valores

# Neon PostgreSQL connection string
# Formato: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://neondb_owner:TU_PASSWORD@TU_HOST.neon.tech/neondb?sslmode=require

# JWT Secret Key — genera uno seguro con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_una_clave_secreta_muy_larga

# Algoritmo de cifrado JWT
ALGORITHM=HS256

# Duracion del token de acceso (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Entorno: development / production
ENVIRONMENT=development
