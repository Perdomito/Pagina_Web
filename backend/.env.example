# ============================================
# VARIABLES DE ENTORNO - BACKEND
# ============================================
# Este archivo debe copiarse como .env y configurarse con los valores reales
# NUNCA subir el archivo .env real a git

# Configuración del servidor
PORT=5000
NODE_ENV=development

# Configuración de la base de datos PostgreSQL (Neon)
# Formato: postgresql://usuario:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://neondb_owner:TU_PASSWORD@TU_HOST.neon.tech/neondb?sslmode=require

# URL de la API Python (FastAPI)
PYTHON_API_URL=https://gnit-api-production.up.railway.app

# Secret para JWT (JSON Web Tokens)
# Generar uno aleatorio con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_secret_key_super_seguro_aqui_cambiar_en_produccion
JWT_EXPIRES_IN=7d

# Configuración de correo (para recuperación de contraseñas)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_password_de_aplicacion

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000