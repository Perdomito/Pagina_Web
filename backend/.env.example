# ============================================
# VARIABLES DE ENTORNO - BACKEND
# ============================================
# Este archivo debe copiarse como .env y configurarse con los valores reales
# NUNCA subir el archivo .env real a git

# Configuración del servidor
PORT=5000
NODE_ENV=development

# Configuración de la base de datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=iglesia_emanuel
DB_PORT=3306

# Secret para JWT (JSON Web Tokens)
# Generar uno aleatorio con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_secret_key_super_seguro_aqui_cambiar_en_produccion

# Configuración de correo (para recuperación de contraseñas)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_password_de_aplicacion

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# ============================================
# NOTAS IMPORTANTES:
# ============================================
# 1. El archivo .env NO debe incluirse en el repositorio git
# 2. Agregar .env al archivo .gitignore
# 3. Cada desarrollador debe crear su propio archivo .env
# 4. En producción, configurar estas variables en el servidor
